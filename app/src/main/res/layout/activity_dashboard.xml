<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Background -->
        <View
            android:id="@+id/viewHeaderBg"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="@color/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title from MainActivity (received via intent) -->
        <TextView
            android:id="@+id/tvDashboardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextWhite"
            android:gravity="center"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/viewHeaderBg"
            app:layout_constraintBottom_toBottomOf="@id/viewHeaderBg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.35" />

        <TextView
            android:id="@+id/tvDashboardDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pilih menu di bawah untuk melanjutkan"
            android:textSize="14sp"
            android:textColor="@color/colorTextWhite"
            android:gravity="center"
            android:alpha="0.8"
            android:layout_marginTop="8dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvDashboardTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Menu Cards -->
        <LinearLayout
            android:id="@+id/layoutMenuCards"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:paddingBottom="30dp"
            app:layout_constraintTop_toBottomOf="@id/viewHeaderBg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Button 1: Rumus Bangun Ruang -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/colorCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivIcon1"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:background="#1A4A90D9"
                        android:padding="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvMenu1Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Bangun Ruang"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivIcon1"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow1" />

                    <TextView
                        android:id="@+id/tvMenu1Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Hitung luas dan volume bangun ruang"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMenu1Title"
                        app:layout_constraintStart_toEndOf="@id/ivIcon1"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow1" />

                    <ImageView
                        android:id="@+id/ivArrow1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_next"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBangunRuang"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="?attr/selectableItemBackground"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Button 2: Custom 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/colorCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivIcon2"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="#1A27AE60"
                        android:padding="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvMenu2Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Custom 1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivIcon2"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow2" />

                    <TextView
                        android:id="@+id/tvMenu2Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Halaman kustom dengan gambar dan teks"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMenu2Title"
                        app:layout_constraintStart_toEndOf="@id/ivIcon2"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow2" />

                    <ImageView
                        android:id="@+id/ivArrow2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_next"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustom1"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="?attr/selectableItemBackground"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Button 3: Custom 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/colorCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivIcon3"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="#1AF39C12"
                        android:padding="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvMenu3Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Custom 2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivIcon3"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow3" />

                    <TextView
                        android:id="@+id/tvMenu3Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Halaman kustom kedua dengan konten berbeda"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMenu3Title"
                        app:layout_constraintStart_toEndOf="@id/ivIcon3"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow3" />

                    <ImageView
                        android:id="@+id/ivArrow3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_next"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustom2"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Button 4: Logout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFEBEE">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivIcon4"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="#1AFF6B6B"
                        android:padding="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvMenu4Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorSecondary"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivIcon4"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow4" />

                    <TextView
                        android:id="@+id/tvMenu4Desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Keluar dari aplikasi"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMenu4Title"
                        app:layout_constraintStart_toEndOf="@id/ivIcon4"
                        app:layout_constraintEnd_toStartOf="@id/ivArrow4" />

                    <ImageView
                        android:id="@+id/ivArrow4"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_next"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        app:backgroundTint="@android:color/transparent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>