<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".Profile.ProfileFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/colorTextWhite" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/colorBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header / Foto Profil -->
            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorGradientEnd"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_edittext"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="44sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Muhammad syabil al jabbar"
                    android:textColor="@color/colorTextWhite"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Android Developer"
                    android:textColor="@color/colorTextHint"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Info Cards -->
            <LinearLayout
                android:id="@+id/layoutCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutHeader">

                <!-- Info Pribadi -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/colorGradientEnd"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informasi Pribadi"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextWhite"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="@color/colorDivider" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Nama" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": Muhammad Syabil Al Jabbar" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="NIM" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": 2457301098" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Kelas" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": 2 SI C" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Prodi" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": Sistem informasi" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kontak -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/colorGradientEnd"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kontak"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextWhite" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="@color/colorDivider" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Email" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": syabil24si@mahasiswa.pcr.ac.id" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="GitHub" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": github.com/syabilpcr" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tentang Aplikasi -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/colorGradientEnd"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tentang Aplikasi"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextWhite" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="@color/colorDivider" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Versi" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": 1.0.0" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Platform" android:textSize="13sp" android:textColor="@color/colorTextPrimary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=": Android (Kotlin)" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/colorTextHint" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>