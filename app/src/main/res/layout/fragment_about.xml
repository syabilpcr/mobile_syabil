<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".About.AboutFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/colorTextWhite" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/colorBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Header Banner -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/colorGradientEnd"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/colorGradientEnd"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BINA DESA"
                        android:textColor="@color/colorTextWhite"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Aplikasi Pemberdayaan Masyarakat Desa"
                        android:textColor="@color/colorTextHint"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Definisi -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDefinisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/colorGradientEnd"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardBanner">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/colorGradientEnd"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Definisi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextWhite"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/colorDivider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bina Desa adalah program pemberdayaan masyarakat yang bertujuan meningkatkan kualitas hidup warga desa melalui pendekatan teknologi digital, edukasi, dan pembangunan infrastruktur sosial yang berkelanjutan."
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/colorTextHint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Visi Misi -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardDefinisi">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/colorGradientEnd"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visi &amp; Misi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextWhite" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/colorDivider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visi"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Mewujudkan desa yang mandiri, inovatif, dan berdaya saing melalui pemanfaatan teknologi digital."
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/colorTextHint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Misi"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="• Meningkatkan literasi digital masyarakat desa\n• Menyediakan platform informasi desa yang terpadu\n• Mendorong partisipasi aktif warga dalam pembangunan\n• Memfasilitasi akses layanan publik berbasis digital"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/colorTextHint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fitur Aplikasi -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFitur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardVisi">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/colorGradientEnd"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fitur Unggulan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextWhite" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/colorDivider" />

                    <!-- Fitur 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text=""
                            android:textSize="20sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kalkulator Dana Desa"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hitung kebutuhan dana pembangunan desa secara akurat"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextHint" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fitur 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text=""
                            android:textSize="20sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sistem Autentikasi Aman"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Login dan registrasi dengan keamanan data terjamin"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextHint" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fitur 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text=""
                            android:textSize="20sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Data Bangunan Desa"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kelola data bangunan dan infrastruktur desa"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextHint" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fitur 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text=""
                            android:textSize="20sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Portal Informasi Web"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Akses informasi dan berita desa terkini via WebView"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextHint" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fitur 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text=""
                            android:textSize="20sp"
                            android:gravity="center" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Navigasi Bottom Navigation"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Navigasi mudah dengan tampilan modern berbasis Fragment"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextHint" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>