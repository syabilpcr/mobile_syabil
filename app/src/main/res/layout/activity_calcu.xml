<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kalkulator Sederhana"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Input Angka 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAngka1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Angka 1"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAngka1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="Masukkan angka pertama" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input Angka 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAngka2"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Angka 2"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tilAngka1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAngka2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="Masukkan angka kedua" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons Row 1: Tambah & Kurang -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTambah"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tambah (+)"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="6dp"
            app:backgroundTint="@color/colorButtonPrimary"
            app:layout_constraintTop_toBottomOf="@id/tilAngka2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnKurang" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKurang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kurang (-)"
            android:layout_marginTop="16dp"
            android:layout_marginStart="6dp"
            app:backgroundTint="@color/colorAccentOrange"
            app:layout_constraintTop_toBottomOf="@id/tilAngka2"
            app:layout_constraintStart_toEndOf="@id/btnTambah"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Buttons Row 2: Kali & Bagi -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKali"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kali (×)"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="6dp"
            app:backgroundTint="@color/colorAccentGreen"
            app:layout_constraintTop_toBottomOf="@id/btnTambah"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnBagi" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBagi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Bagi (÷)"
            android:layout_marginTop="8dp"
            android:layout_marginStart="6dp"
            app:backgroundTint="@color/colorSecondary"
            app:layout_constraintTop_toBottomOf="@id/btnKurang"
            app:layout_constraintStart_toEndOf="@id/btnKali"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:layout_constraintTop_toBottomOf="@id/btnKali"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hasil:"
                    android:textSize="14sp"
                    android:textColor="@color/colorTextSecondary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHasil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>